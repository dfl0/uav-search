{
    "SettingsVersion": 1.2,
    "SimMode": "Multirotor",
    "ClockType": "ScalableClock",
    "ClockSpeed": 1.0,

    "DefaultSensors": {
        "Barometer":    { "SensorType": 1, "Enabled": false },
        "Imu":          { "SensorType": 2, "Enabled": true, "UpdateFrequency": 10 },
        "Gps":          { "SensorType": 3, "Enabled": true, "UpdateFrequency": 10 },
        "Magnetometer": { "SensorType": 4, "Enabled": false },
        "Distance": { "SensorType": 5, "Enabled": true, "UpdateFrequency": 10 },
        "Lidar2": { "SensorType": 6, "Enabled": false }
    },

    "CameraDefaults": {
        "X": 0, "Y": 0, "Z": 0.3,
        "Pitch": -45, "Roll": 0, "Yaw": 0,
        "CaptureSettings": [
            {
                "ImageType": 0,
                "Width": 640,
                "Height": 480,
                "FOV_Degrees": 90
            },
            {
                "ImageType": 1,
                "Width": 60,
                "Height": 80,
                "FOV_Degrees": 90
            }
        ]
    },

    "Vehicles": {
        "drone_1": {
            "VehicleType": "SimpleFlight",
            "DefaultVehicleState": "Armed",
            "AutoCreate": true,
            "X": 0, "Y": 0, "Z": 0,
            "Cameras": {
                "mono_camera": {}
            }
        },

        "drone_2": {
            "VehicleType": "SimpleFlight",
            "DefaultVehicleState": "Armed",
            "AutoCreate": true,
            "X": 2, "Y": 0, "Z": 0,
            "Cameras": {
                "mono_camera": {}
            }
        }

    },

    "SubWindows": [
        { "WindowID": 0, "CameraName": "mono_camera", "ImageType": 0, "VehicleName": "drone_1" },
        { "WindowID": 1, "CameraName": "mono_camera", "ImageType": 0, "VehicleName": "drone_2" },
        { "WindowID": 2, "CameraName": "mono_camera",    "ImageType": 1, "VehicleName": "drone_1" }
    ]
}
